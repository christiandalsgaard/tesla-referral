# Resend API key — get one at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxx

# Neon Postgres connection string — get one at https://neon.tech or via Vercel Marketplace
DATABASE_URL=postgres://user:pass@host/dbname?sslmode=require

# Simple password to protect the dashboard (change this!)
DASHBOARD_PASSWORD=change-me-to-something-secure

# Public-facing site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
